---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="Blog — Alex Rivera" description="Thoughts on web development, design systems, TypeScript, and building better software.">
  <main class="max-w-6xl mx-auto px-6 pt-24 pb-16">
    <div class="mb-12">
      <h1 class="text-4xl font-bold mb-3" style="color: var(--text);">
        <span class="gradient-text">Blog</span>
      </h1>
      <p class="text-lg" style="color: var(--muted);">Thoughts on web development, design systems, and building better software.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {posts.map((post, i) => (
        <a href={`/blog/${post.id}`} class:list={["bento-card group", i === 0 ? "lg:col-span-2 lg:row-span-2" : "lg:col-span-2"]}>
          <div class="flex flex-col h-full">
            <div class="flex items-center gap-2 mb-3">
              <time class="text-xs" style="color: var(--muted);">
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
              {post.data.tags.slice(0, 2).map(tag => (
                <span class="text-xs px-2 py-0.5 rounded-md" style="background-color: var(--accent-violet); color: white; opacity: 0.8;">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class:list={["font-bold mb-2 group-hover:underline", i === 0 ? "text-2xl" : "text-lg"]} style="color: var(--text);">
              {post.data.title}
            </h2>
            <p class="text-sm leading-relaxed flex-1" style="color: var(--muted);">{post.data.description}</p>
            <span class="text-sm font-medium mt-4 gradient-text">Read more →</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
