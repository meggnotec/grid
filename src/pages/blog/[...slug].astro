---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} — Alex Rivera`} description={post.data.description}>
  <main class="max-w-3xl mx-auto px-6 pt-24 pb-16">
    <article>
      <div class="mb-8">
        <a href="/blog" class="inline-flex items-center gap-1 text-sm mb-6 transition-colors gradient-text">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Back to Blog
        </a>
        <div class="flex items-center gap-2 mb-4">
          <time class="text-sm" style="color: var(--muted);">
            {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>
          {post.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-md" style="background-color: var(--accent-violet); color: white; opacity: 0.8;">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="text-4xl font-bold leading-tight" style="color: var(--text);">{post.data.title}</h1>
        <p class="text-lg mt-3" style="color: var(--muted);">{post.data.description}</p>
      </div>

      <div class="prose prose-invert max-w-none" style="color: var(--muted);">
        <style>
          .prose h2 { color: var(--text); font-size: 1.5rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; }
          .prose h3 { color: var(--text); font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; }
          .prose p { margin-bottom: 1rem; line-height: 1.75; }
          .prose ul, .prose ol { margin-bottom: 1rem; padding-left: 1.5rem; }
          .prose li { margin-bottom: 0.5rem; line-height: 1.75; }
          .prose strong { color: var(--text); font-weight: 600; }
          .prose code { background-color: var(--card); padding: 0.15rem 0.4rem; border-radius: 0.25rem; font-size: 0.875rem; color: var(--accent-violet); }
          .prose pre { background-color: var(--card); border: 1px solid var(--border); border-radius: 0.75rem; padding: 1.25rem; margin-bottom: 1.5rem; overflow-x: auto; }
          .prose pre code { background: none; padding: 0; color: var(--text); }
          .prose a { color: var(--accent-violet); text-decoration: underline; }
          .prose blockquote { border-left: 3px solid var(--accent-violet); padding-left: 1rem; font-style: italic; color: var(--muted); }
        </style>
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
