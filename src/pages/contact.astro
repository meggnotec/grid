---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../data/site-config.json';
---
<BaseLayout title="Contact — Alex Rivera" description="Get in touch for collaborations, freelance work, or just to say hello.">
  <main class="max-w-6xl mx-auto px-6 pt-24 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">

      <!-- Header: 2 cols -->
      <div class="bento-card lg:col-span-2 !p-8">
        <h1 class="text-4xl font-bold mb-3" style="color: var(--text);">
          <span class="gradient-text">Get in Touch</span>
        </h1>
        <p class="text-lg leading-relaxed" style="color: var(--muted);">
          Have a project in mind, want to collaborate, or just want to say hello? I'd love to hear from you. Fill out the form or reach out through any of the channels below.
        </p>
      </div>

      <!-- Email: 1 col -->
      <div class="bento-card flex flex-col items-center justify-center text-center">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent-violet)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-3">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        <p class="text-sm font-semibold" style="color: var(--text);">Email</p>
        <a href={`mailto:${siteConfig.email}`} class="text-sm gradient-text">{siteConfig.email}</a>
      </div>

      <!-- Response Time: 1 col -->
      <div class="bento-card flex flex-col items-center justify-center text-center gradient-bg !border-transparent">
        <p class="text-3xl font-bold text-white mb-1">&lt; 24h</p>
        <p class="text-sm text-white/70">Response Time</p>
      </div>

      <!-- Contact Form: 4 cols -->
      <div class="bento-card lg:col-span-4 !p-8">
        <h2 class="text-lg font-semibold mb-6" style="color: var(--text);">Send a Message</h2>
        <form class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-sm font-medium mb-1.5" style="color: var(--muted);">Name</label>
            <input type="text" id="name" name="name" required
              class="w-full px-4 py-2.5 rounded-lg text-sm outline-none transition-colors"
              style="background-color: var(--bg); border: 1px solid var(--border); color: var(--text);"
              placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-1.5" style="color: var(--muted);">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-2.5 rounded-lg text-sm outline-none transition-colors"
              style="background-color: var(--bg); border: 1px solid var(--border); color: var(--text);"
              placeholder="you@example.com" />
          </div>
          <div class="md:col-span-2">
            <label for="subject" class="block text-sm font-medium mb-1.5" style="color: var(--muted);">Subject</label>
            <input type="text" id="subject" name="subject" required
              class="w-full px-4 py-2.5 rounded-lg text-sm outline-none transition-colors"
              style="background-color: var(--bg); border: 1px solid var(--border); color: var(--text);"
              placeholder="Project inquiry" />
          </div>
          <div class="md:col-span-2">
            <label for="message" class="block text-sm font-medium mb-1.5" style="color: var(--muted);">Message</label>
            <textarea id="message" name="message" rows="5" required
              class="w-full px-4 py-2.5 rounded-lg text-sm outline-none transition-colors resize-y"
              style="background-color: var(--bg); border: 1px solid var(--border); color: var(--text);"
              placeholder="Tell me about your project..."></textarea>
          </div>
          <div class="md:col-span-2">
            <button type="submit" class="px-8 py-2.5 rounded-lg font-medium text-white gradient-bg transition-opacity hover:opacity-90">
              Send Message
            </button>
          </div>
        </form>
      </div>

      <!-- Social Links: 2 cols -->
      <div class="bento-card lg:col-span-2">
        <h2 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--muted);">Other Ways to Connect</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href={siteConfig.social.github} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors" style="background-color: var(--bg); color: var(--text);" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            <div>
              <p class="text-sm font-medium">GitHub</p>
              <p class="text-xs" style="color: var(--muted);">@alexrivera</p>
            </div>
          </a>
          <a href={siteConfig.social.twitter} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors" style="background-color: var(--bg); color: var(--text);" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <div>
              <p class="text-sm font-medium">Twitter</p>
              <p class="text-xs" style="color: var(--muted);">@alexrivera</p>
            </div>
          </a>
          <a href={siteConfig.social.linkedin} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors" style="background-color: var(--bg); color: var(--text);" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <div>
              <p class="text-sm font-medium">LinkedIn</p>
              <p class="text-xs" style="color: var(--muted);">in/alexrivera</p>
            </div>
          </a>
          <a href={siteConfig.social.dribbble} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors" style="background-color: var(--bg); color: var(--text);" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 24C5.385 24 0 18.615 0 12S5.385 0 12 0s12 5.385 12 12-5.385 12-12 12zm10.12-10.358c-.35-.11-3.17-.953-6.384-.438 1.34 3.684 1.887 6.684 1.992 7.308 2.3-1.555 3.936-4.02 4.395-6.87zm-6.115 7.808c-.153-.9-.75-4.032-2.19-7.77l-.066.02c-5.79 2.015-7.86 6.025-8.04 6.4 1.73 1.358 3.92 2.166 6.29 2.166 1.42 0 2.77-.29 4-.81zm-11.62-2.58c.232-.4 3.045-5.055 8.332-6.765.135-.045.27-.084.405-.12-.26-.585-.54-1.167-.832-1.74C7.17 11.775 2.206 11.71 1.756 11.7l-.004.312c0 2.633.998 5.037 2.634 6.855zm-2.42-8.955c.46.008 4.683.026 9.477-1.248-1.698-3.018-3.53-5.558-3.8-5.928-2.868 1.35-5.01 3.99-5.676 7.17zM9.6 2.052c.282.38 2.145 2.914 3.822 6 3.645-1.365 5.19-3.44 5.373-3.702-1.81-1.61-4.19-2.586-6.795-2.586-.825 0-1.63.1-2.4.29zm10.335 3.483c-.218.29-1.91 2.493-5.724 4.04.24.49.47.985.68 1.486.08.18.15.36.22.53 3.41-.43 6.8.26 7.14.33-.02-2.42-.88-4.64-2.31-6.38z"/></svg>
            <div>
              <p class="text-sm font-medium">Dribbble</p>
              <p class="text-xs" style="color: var(--muted);">@alexrivera</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Availability: 2 cols -->
      <div class="bento-card lg:col-span-2 flex items-center gap-4">
        <div class="w-3 h-3 rounded-full bg-green-400 animate-pulse shrink-0"></div>
        <div>
          <p class="font-semibold" style="color: var(--text);">Currently available for freelance work</p>
          <p class="text-sm" style="color: var(--muted);">Open to full-time roles, contract work, and interesting open-source collaborations.</p>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>
