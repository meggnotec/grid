---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';
---
<BaseLayout title="Projects — Alex Rivera" description="A collection of open-source tools, libraries, and applications I've built.">
  <main class="max-w-6xl mx-auto px-6 pt-24 pb-16">
    <div class="mb-12">
      <h1 class="text-4xl font-bold mb-3" style="color: var(--text);">
        <span class="gradient-text">Projects</span>
      </h1>
      <p class="text-lg" style="color: var(--muted);">Open-source tools, libraries, and applications I've built and maintain.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {projects.map(project => (
        <ProjectCard
          title={project.title}
          description={project.description}
          tags={project.tags}
          github={project.github}
          live={project.live}
          stars={project.stars}
          color={project.color}
        />
      ))}
    </div>
  </main>
</BaseLayout>
