---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillIcon from '../components/SkillIcon.astro';
import ProjectCard from '../components/ProjectCard.astro';
import siteConfig from '../data/site-config.json';
import projects from '../data/projects.json';

const featuredProjects = projects.filter(p => p.featured);
---
<BaseLayout title={`${siteConfig.name} — ${siteConfig.title}`}>
  <main class="max-w-6xl mx-auto px-6 pt-24 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">

      <!-- ═══════════ HERO: 2 cols × 2 rows ═══════════ -->
      <div class="bento-card lg:col-span-2 lg:row-span-2 relative overflow-hidden !p-8">
        <!-- Dot pattern background -->
        <div class="absolute inset-0 dot-pattern opacity-30" aria-hidden="true"></div>
        <div class="relative z-10">
          <div class="mb-6">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium mb-4" style="background-color: var(--accent-violet); background: linear-gradient(135deg, var(--accent-violet), var(--accent-blue)); color: white; opacity: 0.9;">
              <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
              Available for work
            </div>
            <h1 class="text-4xl lg:text-5xl font-bold mb-3 leading-tight" style="color: var(--text);">
              <span class="gradient-text">{siteConfig.name}</span>
            </h1>
            <p class="text-xl font-medium mb-4" style="color: var(--text);">{siteConfig.title}</p>
            <p class="text-base leading-relaxed mb-8" style="color: var(--muted);">{siteConfig.bio}</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/projects" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg font-medium text-white gradient-bg transition-opacity hover:opacity-90">
              View Projects
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="/about" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg font-medium transition-colors" style="color: var(--text); border: 1px solid var(--border);">
              About Me
            </a>
          </div>
        </div>
      </div>

      <!-- ═══════════ STATS: 4 × 1 col cards ═══════════ -->
      {siteConfig.stats.map((stat: { value: string; label: string }) => (
        <div class="bento-card flex flex-col items-center justify-center text-center">
          <div class="text-3xl font-bold mb-1 gradient-text">{stat.value}</div>
          <div class="text-sm" style="color: var(--muted);">{stat.label}</div>
        </div>
      ))}

      <!-- ═══════════ ABOUT: 2 cols ═══════════ -->
      <div class="bento-card lg:col-span-2">
        <div class="flex gap-5 items-start">
          <div class="w-14 h-14 rounded-xl gradient-bg flex items-center justify-center text-white font-bold text-lg shrink-0">
            AR
          </div>
          <div>
            <h2 class="text-lg font-semibold mb-2" style="color: var(--text);">About Me</h2>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">{siteConfig.about}</p>
          </div>
        </div>
      </div>

      <!-- ═══════════ SKILLS: 1 col ═══════════ -->
      <div class="bento-card">
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--muted);">Skills</h3>
        <div class="grid grid-cols-4 gap-3">
          {siteConfig.skills.map((skill: { name: string; icon: string }) => (
            <SkillIcon name={skill.name} icon={skill.icon} />
          ))}
        </div>
      </div>

      <!-- ═══════════ CONNECT: 1 col ═══════════ -->
      <div class="bento-card">
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--muted);">Connect</h3>
        <div class="grid grid-cols-2 gap-3">
          <a href={siteConfig.social.github} class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors" style="background-color: var(--bg); color: var(--text);" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href={siteConfig.social.twitter} class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors" style="background-color: var(--bg); color: var(--text);" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Twitter
          </a>
          <a href={siteConfig.social.linkedin} class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors" style="background-color: var(--bg); color: var(--text);" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href={`mailto:${siteConfig.email}`} class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors" style="background-color: var(--bg); color: var(--text);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Email
          </a>
        </div>
      </div>

      <!-- ═══════════ FEATURED PROJECTS ═══════════ -->
      {featuredProjects.map(project => (
        <ProjectCard
          title={project.title}
          description={project.description}
          tags={project.tags}
          github={project.github}
          live={project.live}
          stars={project.stars}
          color={project.color}
        />
      ))}

      <!-- ═══════════ LATEST BLOG: 2 cols ═══════════ -->
      <div class="bento-card lg:col-span-2">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--muted);">Latest Posts</h3>
          <a href="/blog" class="text-xs font-medium transition-colors gradient-text">View All →</a>
        </div>
        <div class="space-y-3">
          <a href="/blog/building-accessible-components" class="flex items-center justify-between py-2 group/post">
            <div>
              <h4 class="text-sm font-medium group-hover/post:underline" style="color: var(--text);">Building Accessible React Components</h4>
              <p class="text-xs mt-0.5" style="color: var(--muted);">A practical guide to ARIA patterns</p>
            </div>
            <span class="text-xs shrink-0 ml-4" style="color: var(--muted);">Mar 15</span>
          </a>
          <div style="border-top: 1px solid var(--border);"></div>
          <a href="/blog/typescript-patterns" class="flex items-center justify-between py-2 group/post">
            <div>
              <h4 class="text-sm font-medium group-hover/post:underline" style="color: var(--text);">Advanced TypeScript Patterns</h4>
              <p class="text-xs mt-0.5" style="color: var(--muted);">Conditional types, infer, and mapped types</p>
            </div>
            <span class="text-xs shrink-0 ml-4" style="color: var(--muted);">Mar 8</span>
          </a>
          <div style="border-top: 1px solid var(--border);"></div>
          <a href="/blog/design-system-tokens" class="flex items-center justify-between py-2 group/post">
            <div>
              <h4 class="text-sm font-medium group-hover/post:underline" style="color: var(--text);">Design System Token Architecture</h4>
              <p class="text-xs mt-0.5" style="color: var(--muted);">Scaling design tokens across platforms</p>
            </div>
            <span class="text-xs shrink-0 ml-4" style="color: var(--muted);">Feb 28</span>
          </a>
        </div>
      </div>

      <!-- ═══════════ CURRENTLY: 1 col ═══════════ -->
      <div class="bento-card">
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--muted);">Currently</h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3">
            <span class="text-lg">🎯</span>
            <div>
              <p class="text-sm font-medium" style="color: var(--text);">Building</p>
              <p class="text-xs" style="color: var(--muted);">Nexus UI v3.0</p>
            </div>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-lg">📚</span>
            <div>
              <p class="text-sm font-medium" style="color: var(--text);">Learning</p>
              <p class="text-xs" style="color: var(--muted);">Rust + WebAssembly</p>
            </div>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-lg">🎧</span>
            <div>
              <p class="text-sm font-medium" style="color: var(--text);">Listening</p>
              <p class="text-xs" style="color: var(--muted);">Syntax Podcast</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- ═══════════ CTA: 1 col ═══════════ -->
      <div class="bento-card flex flex-col items-center justify-center text-center gradient-bg !border-transparent">
        <h3 class="text-lg font-bold text-white mb-2">Let's Work Together</h3>
        <p class="text-sm text-white/70 mb-4">Have a project in mind?</p>
        <a href="/contact" class="px-5 py-2 rounded-lg text-sm font-medium transition-colors" style="background-color: white; color: #09090B;">
          Get in Touch
        </a>
      </div>

    </div>
  </main>
</BaseLayout>
