---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../data/site-config.json';
import Icons from '../components/Icons.astro';

const skillCategories = [
  { name: 'Frontend', skills: siteConfig.skills.filter((s) => s.category === 'Frontend') },
  { name: 'Languages', skills: siteConfig.skills.filter((s) => s.category === 'Languages') },
  { name: 'Backend', skills: siteConfig.skills.filter((s) => s.category === 'Backend') },
  { name: 'DevOps', skills: siteConfig.skills.filter((s) => s.category === 'DevOps') },
];
---

<BaseLayout title="About" description="Learn more about my background, skills, and experience as a full-stack engineer.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-24 pb-16">
    <!-- Intro -->
    <div class="mb-16 animate-fade-in animate-delay-1">
      <h1 class="text-3xl sm:text-4xl font-bold mb-6" style="color: var(--text);">
        <span class="gradient-text">About Me</span>
      </h1>
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <div class="shrink-0 w-28 h-28 rounded-2xl p-[2px]" style="background: linear-gradient(135deg, var(--color-accent-violet), var(--color-accent-blue));">
          <div class="w-full h-full rounded-2xl flex items-center justify-center text-3xl font-bold" style="background-color: var(--card); color: var(--text);">
            AR
          </div>
        </div>
        <div>
          <p class="text-lg leading-relaxed mb-4" style="color: var(--muted);">
            {siteConfig.bio}
          </p>
          <div class="flex items-center gap-2 text-sm" style="color: var(--muted);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />
            </svg>
            {siteConfig.location}
          </div>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="mb-16 animate-fade-in animate-delay-2">
      <h2 class="text-2xl font-bold mb-8" style="color: var(--text);">Experience</h2>
      <div class="relative pl-8 border-l-2" style="border-color: var(--border);">
        {siteConfig.timeline.map((item, i) => (
          <div class={`mb-10 last:mb-0 relative ${i > 0 ? '' : ''}`}>
            <div class="absolute -left-[calc(2rem+5px)] w-3 h-3 rounded-full" style="background: linear-gradient(135deg, var(--color-accent-violet), var(--color-accent-blue)); top: 4px;"></div>
            <span class="text-xs font-medium px-2.5 py-1 rounded-full mb-2 inline-block" style="background-color: var(--card); color: var(--muted); border: 1px solid var(--border);">
              {item.year}
            </span>
            <h3 class="text-lg font-semibold mt-2" style="color: var(--text);">{item.title}</h3>
            <p class="text-sm font-medium mb-2 gradient-text">{item.company}</p>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">{item.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Skills -->
    <div class="mb-16 animate-fade-in animate-delay-3">
      <h2 class="text-2xl font-bold mb-8" style="color: var(--text);">Skills</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {skillCategories.map((cat) => (
          <div class="gradient-border-hover overflow-hidden p-5" style="background-color: var(--card);">
            <h3 class="text-sm font-semibold uppercase tracking-wider mb-3" style="color: var(--muted);">{cat.name}</h3>
            <div class="flex flex-wrap gap-2">
              {cat.skills.map((skill) => (
                <span class="text-sm font-medium px-3 py-1.5 rounded-lg" style="background-color: var(--bg); color: var(--text); border: 1px solid var(--border);">
                  {skill.name}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div class="mb-16 animate-fade-in animate-delay-4">
      <h2 class="text-2xl font-bold mb-8" style="color: var(--text);">Education</h2>
      {siteConfig.education.map((edu) => (
        <div class="gradient-border-hover overflow-hidden p-5" style="background-color: var(--card);">
          <h3 class="text-lg font-semibold" style="color: var(--text);">{edu.degree}</h3>
          <p class="text-sm" style="color: var(--muted);">{edu.school} &middot; {edu.year}</p>
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <div class="animate-fade-in animate-delay-5">
      <h2 class="text-2xl font-bold mb-8" style="color: var(--text);">What People Say</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {siteConfig.testimonials.map((t) => (
          <div class="gradient-border-hover overflow-hidden p-5 flex flex-col" style="background-color: var(--card);">
            <Icons name="quote" size={32} />
            <p class="text-sm leading-relaxed mb-4 flex-1 italic" style="color: var(--muted);">
              &ldquo;{t.quote}&rdquo;
            </p>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-bold" style="background: linear-gradient(135deg, var(--color-accent-violet), var(--color-accent-blue)); color: white;">
                {t.name.split(' ').map((n) => n[0]).join('')}
              </div>
              <div>
                <p class="text-sm font-semibold" style="color: var(--text);">{t.name}</p>
                <p class="text-xs" style="color: var(--muted);">{t.role}, {t.company}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
