---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillIcon from '../components/SkillIcon.astro';
import siteConfig from '../data/site-config.json';

const experience = [
  {
    role: "Senior Frontend Engineer",
    company: "Vercel",
    period: "2022 — Present",
    description: "Leading the design systems team, building accessible component libraries used across all Vercel products."
  },
  {
    role: "Full-Stack Developer",
    company: "Stripe",
    period: "2019 — 2022",
    description: "Built payment dashboard features, optimized performance for high-traffic merchant pages, and contributed to the internal design system."
  },
  {
    role: "Frontend Developer",
    company: "GitHub",
    period: "2017 — 2019",
    description: "Worked on the Primer design system and contributed to the main GitHub web application, focusing on accessibility and performance."
  },
  {
    role: "Junior Developer",
    company: "Freelance",
    period: "2015 — 2017",
    description: "Built websites and web applications for small businesses and startups, focusing on responsive design and clean code."
  }
];
---
<BaseLayout title="About — Alex Rivera" description="Learn more about Alex Rivera, a full-stack developer and UI designer with 8+ years of experience.">
  <main class="max-w-6xl mx-auto px-6 pt-24 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">

      <!-- Header: 2 cols -->
      <div class="bento-card lg:col-span-2 !p-8">
        <div class="flex items-center gap-5 mb-6">
          <div class="w-20 h-20 rounded-2xl gradient-bg flex items-center justify-center text-white font-bold text-2xl shrink-0">
            AR
          </div>
          <div>
            <h1 class="text-3xl font-bold" style="color: var(--text);">
              <span class="gradient-text">{siteConfig.name}</span>
            </h1>
            <p class="text-lg" style="color: var(--muted);">{siteConfig.title}</p>
          </div>
        </div>
        <p class="leading-relaxed" style="color: var(--muted);">{siteConfig.about}</p>
      </div>

      <!-- Location: 1 col -->
      <div class="bento-card flex flex-col items-center justify-center text-center">
        <span class="text-4xl mb-2">📍</span>
        <p class="font-semibold" style="color: var(--text);">San Francisco, CA</p>
        <p class="text-sm" style="color: var(--muted);">United States</p>
      </div>

      <!-- Education: 1 col -->
      <div class="bento-card flex flex-col items-center justify-center text-center">
        <span class="text-4xl mb-2">🎓</span>
        <p class="font-semibold" style="color: var(--text);">CS @ Stanford</p>
        <p class="text-sm" style="color: var(--muted);">Class of 2015</p>
      </div>

      <!-- Skills: 4 cols -->
      <div class="bento-card lg:col-span-4">
        <h2 class="text-sm font-semibold uppercase tracking-wider mb-6" style="color: var(--muted);">Technical Skills</h2>
        <div class="grid grid-cols-4 sm:grid-cols-8 gap-4">
          {siteConfig.skills.map((skill: { name: string; icon: string }) => (
            <SkillIcon name={skill.name} icon={skill.icon} />
          ))}
        </div>
      </div>

      <!-- Experience: 4 cols -->
      <div class="bento-card lg:col-span-4">
        <h2 class="text-sm font-semibold uppercase tracking-wider mb-6" style="color: var(--muted);">Experience</h2>
        <div class="space-y-6">
          {experience.map((job, i) => (
            <div class="flex gap-4" style={i < experience.length - 1 ? `padding-bottom: 1.5rem; border-bottom: 1px solid var(--border);` : ''}>
              <div class="w-10 h-10 rounded-lg gradient-bg flex items-center justify-center text-white text-sm font-bold shrink-0">
                {job.company.charAt(0)}
              </div>
              <div>
                <h3 class="font-semibold" style="color: var(--text);">{job.role}</h3>
                <p class="text-sm mb-1" style="color: var(--accent-violet);">{job.company} · {job.period}</p>
                <p class="text-sm leading-relaxed" style="color: var(--muted);">{job.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </main>
</BaseLayout>
