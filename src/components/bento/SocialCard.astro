---
import siteConfig from '../../data/site-config.json';
import BentoCard from '../BentoCard.astro';
import Icons from '../Icons.astro';

const socials = [
  { name: 'GitHub', icon: 'github', href: siteConfig.social.github },
  { name: 'Twitter', icon: 'twitter', href: siteConfig.social.twitter },
  { name: 'LinkedIn', icon: 'linkedin', href: siteConfig.social.linkedin },
  { name: 'Email', icon: 'email', href: siteConfig.social.email },
];
---

<BentoCard class="flex flex-col">
  <h3 class="text-sm font-semibold mb-4 uppercase tracking-wider" style="color: var(--muted);">Connect</h3>
  <div class="grid grid-cols-2 gap-3 flex-1 items-center">
    {socials.map((social) => (
      <a
        href={social.href}
        target={social.icon !== 'email' ? '_blank' : undefined}
        rel={social.icon !== 'email' ? 'noopener noreferrer' : undefined}
        class="flex flex-col items-center gap-2 p-3 rounded-lg transition-all hover:scale-105"
        style="color: var(--muted); background-color: var(--bg);"
        aria-label={social.name}
      >
        <Icons name={social.icon} size={20} />
        <span class="text-[10px] font-medium">{social.name}</span>
      </a>
    ))}
  </div>
</BentoCard>
