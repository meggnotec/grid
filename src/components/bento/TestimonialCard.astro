---
import siteConfig from '../../data/site-config.json';
import BentoCard from '../BentoCard.astro';
import Icons from '../Icons.astro';

const testimonial = siteConfig.testimonials[0];
---

<BentoCard class="col-span-1 md:col-span-2 relative">
  <div class="absolute top-4 right-4">
    <Icons name="quote" size={48} />
  </div>
  <div class="relative z-10">
    <p class="text-sm leading-relaxed mb-4 italic" style="color: var(--muted);">
      &ldquo;{testimonial.quote}&rdquo;
    </p>
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold" style="background: linear-gradient(135deg, var(--color-accent-violet), var(--color-accent-blue)); color: white;">
        {testimonial.name.split(' ').map((n) => n[0]).join('')}
      </div>
      <div>
        <p class="text-sm font-semibold" style="color: var(--text);">{testimonial.name}</p>
        <p class="text-xs" style="color: var(--muted);">{testimonial.role}, {testimonial.company}</p>
      </div>
    </div>
  </div>
</BentoCard>
