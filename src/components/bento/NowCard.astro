---
import siteConfig from '../../data/site-config.json';
import BentoCard from '../BentoCard.astro';
---

<BentoCard class="flex flex-col">
  <h3 class="text-sm font-semibold mb-4 uppercase tracking-wider" style="color: var(--muted);">Currently</h3>
  <div class="flex flex-col gap-3 flex-1 justify-center">
    <div class="flex items-start gap-2">
      <span class="text-sm">🛠</span>
      <div>
        <p class="text-[10px] uppercase tracking-wider font-medium" style="color: var(--muted);">Working on</p>
        <p class="text-xs font-medium" style="color: var(--text);">{siteConfig.currently.working}</p>
      </div>
    </div>
    <div class="flex items-start gap-2">
      <span class="text-sm">📖</span>
      <div>
        <p class="text-[10px] uppercase tracking-wider font-medium" style="color: var(--muted);">Reading</p>
        <p class="text-xs font-medium" style="color: var(--text);">{siteConfig.currently.reading}</p>
      </div>
    </div>
    <div class="flex items-start gap-2">
      <span class="text-sm">🎧</span>
      <div>
        <p class="text-[10px] uppercase tracking-wider font-medium" style="color: var(--muted);">Listening to</p>
        <p class="text-xs font-medium" style="color: var(--text);">{siteConfig.currently.listening}</p>
      </div>
    </div>
  </div>
</BentoCard>
