---
import siteConfig from '../../data/site-config.json';
import BentoCard from '../BentoCard.astro';
---

<BentoCard href={siteConfig.social.email} class="flex flex-col items-center justify-center text-center">
  <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: linear-gradient(135deg, var(--color-accent-violet), var(--color-accent-blue));">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2" />
      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
    </svg>
  </div>
  <p class="text-sm font-semibold mb-1" style="color: var(--text);">Let's Work Together</p>
  <p class="text-xs" style="color: var(--muted);">Get in touch</p>
</BentoCard>
