---
import siteConfig from '../../data/site-config.json';
import BentoCard from '../BentoCard.astro';
---

<BentoCard class="col-span-1 md:col-span-2 flex flex-col sm:flex-row items-center gap-6">
  <div class="shrink-0 w-24 h-24 rounded-2xl p-[2px]" style="background: linear-gradient(135deg, var(--color-accent-violet), var(--color-accent-blue));">
    <div class="w-full h-full rounded-2xl flex items-center justify-center text-2xl font-bold relative overflow-hidden" style="background-color: var(--card); color: var(--text);">
      <div class="absolute inset-0 dot-grid opacity-30"></div>
      <span class="relative z-10 gradient-text text-3xl">AR</span>
    </div>
  </div>
  <div>
    <h2 class="text-lg font-semibold mb-2" style="color: var(--text);">About Me</h2>
    <p class="text-sm leading-relaxed" style="color: var(--muted);">
      {siteConfig.bio}
    </p>
  </div>
</BentoCard>
