---
import BentoCard from '../BentoCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latest = posts[0];
---

<BentoCard href={latest ? `/blog/${latest.id}` : '/blog'} class="flex flex-col justify-between">
  <div>
    <h3 class="text-sm font-semibold mb-3 uppercase tracking-wider" style="color: var(--muted);">Latest Post</h3>
    {latest && (
      <>
        <h4 class="text-base font-semibold mb-2 leading-snug" style="color: var(--text);">{latest.data.title}</h4>
        <p class="text-xs" style="color: var(--muted);">
          {new Date(latest.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
        </p>
      </>
    )}
  </div>
  <p class="text-sm font-medium mt-4 gradient-text">Read &rarr;</p>
</BentoCard>
