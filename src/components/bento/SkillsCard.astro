---
import siteConfig from '../../data/site-config.json';
import BentoCard from '../BentoCard.astro';
import Icons from '../Icons.astro';

const iconMap: Record<string, string> = {
  'React': 'react',
  'TypeScript': 'typescript',
  'Node.js': 'nodejs',
  'Python': 'python',
  'Tailwind': 'tailwind',
  'PostgreSQL': 'postgresql',
  'Docker': 'docker',
  'AWS': 'aws',
};
---

<BentoCard class="flex flex-col">
  <h3 class="text-sm font-semibold mb-4 uppercase tracking-wider" style="color: var(--muted);">Skills</h3>
  <div class="grid grid-cols-4 gap-3 flex-1 items-center">
    {siteConfig.skills.map((skill) => (
      <div class="flex flex-col items-center gap-1.5 group">
        <div class="p-2 rounded-lg transition-colors" style="color: var(--muted);">
          <Icons name={iconMap[skill.name] || 'react'} size={20} />
        </div>
        <span class="text-[10px] font-medium" style="color: var(--muted);">{skill.name}</span>
      </div>
    ))}
  </div>
</BentoCard>
