---
import BentoCard from '../BentoCard.astro';

interface Props {
  value: number;
  label: string;
  suffix: string;
}

const { value, label, suffix } = Astro.props;
---

<BentoCard class="flex flex-col items-center justify-center text-center min-h-[140px]">
  <p class="text-3xl md:text-4xl font-bold mb-1" style="color: var(--text);">
    <span class="stat-number" data-target={value}>{value}</span>{suffix}
  </p>
  <p class="text-sm font-medium" style="color: var(--muted);">{label}</p>
</BentoCard>
