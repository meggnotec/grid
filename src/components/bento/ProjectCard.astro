---
import BentoCard from '../BentoCard.astro';

interface Props {
  title: string;
  description: string;
  tech: string[];
  liveUrl: string;
  githubUrl: string;
}

const { title, description, tech, liveUrl, githubUrl } = Astro.props;
---

<BentoCard class="col-span-1 md:col-span-2 flex flex-col">
  <div class="w-full h-32 rounded-lg mb-4 flex items-center justify-center relative overflow-hidden" style="background-color: var(--bg);">
    <div class="absolute inset-0 dot-grid opacity-40"></div>
    <div class="absolute inset-0 opacity-10" style="background: linear-gradient(135deg, var(--color-accent-violet), var(--color-accent-blue));"></div>
    <div class="relative w-14 h-14 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-accent-violet), var(--color-accent-blue));">
      <span class="text-xl font-bold text-white">{title[0]}</span>
    </div>
  </div>
  <h3 class="text-lg font-semibold mb-1" style="color: var(--text);">{title}</h3>
  <p class="text-sm mb-3 flex-1" style="color: var(--muted);">{description}</p>
  <div class="flex flex-wrap gap-2 mb-4">
    {tech.map((t) => (
      <span class="text-xs px-2.5 py-1 rounded-md font-medium" style="background-color: var(--bg); color: var(--muted); border: 1px solid var(--border);">
        {t}
      </span>
    ))}
  </div>
  <div class="flex items-center gap-3">
    {liveUrl && (
      <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="text-xs font-medium flex items-center gap-1 transition-colors hover:opacity-80" style="color: var(--text);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
          <polyline points="15 3 21 3 21 9" />
          <line x1="10" y1="14" x2="21" y2="3" />
        </svg>
        Live
      </a>
    )}
    {githubUrl && (
      <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-xs font-medium flex items-center gap-1 transition-colors hover:opacity-80" style="color: var(--muted);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Source
      </a>
    )}
  </div>
</BentoCard>
