---
import siteConfig from '../../data/site-config.json';
import BentoCard from '../BentoCard.astro';
---

<BentoCard class="relative col-span-1 md:col-span-2 row-span-2 flex flex-col justify-end min-h-[320px] md:min-h-[400px]">
  <div class="absolute inset-0 dot-grid opacity-30"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[var(--card)] via-[var(--card)]/80 to-transparent"></div>
  <div class="relative z-10">
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-3">
      <span class="gradient-text">{siteConfig.name}</span>
    </h1>
    <p class="text-xl md:text-2xl font-medium mb-2" style="color: var(--text);">{siteConfig.title}</p>
    <p class="text-base md:text-lg mb-6 max-w-lg" style="color: var(--muted);">
      {siteConfig.description}
    </p>
    <div class="flex flex-wrap gap-3">
      <a
        href="/projects"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium text-white transition-all hover:opacity-90"
        style="background: linear-gradient(135deg, var(--color-accent-violet), var(--color-accent-blue));"
      >
        View Projects
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      <a
        href="/about"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium border transition-all hover:opacity-80"
        style="color: var(--text); border-color: var(--border);"
      >
        About Me
      </a>
    </div>
  </div>
</BentoCard>
