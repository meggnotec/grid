---
import siteConfig from '../data/site-config.json';
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <nav class="flex items-center justify-between h-16" aria-label="Main navigation">
      <a href="/" class="text-lg font-bold tracking-tight hover:opacity-80 transition-opacity" style="color: var(--text);">
        {siteConfig.name}<span class="gradient-text">.</span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        {siteConfig.nav.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
                isActive ? 'gradient-text' : 'hover:opacity-80',
              ]}
              style={!isActive ? 'color: var(--muted);' : undefined}
            >
              {item.label}
            </a>
          );
        })}
        <ThemeToggle />
      </div>

      <div class="flex items-center gap-2 md:hidden">
        <ThemeToggle />
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-lg transition-colors"
          style="color: var(--muted);"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="menu-open-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg id="menu-close-icon" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t" style="border-color: var(--border); background-color: var(--bg);">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-1">
      {siteConfig.nav.map((item) => {
        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
              isActive ? 'gradient-text' : '',
            ]}
            style={!isActive ? 'color: var(--muted);' : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </div>
  </div>
</header>

<script is:inline>
  (function() {
    const header = document.getElementById('site-header');
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const openIcon = document.getElementById('menu-open-icon');
    const closeIcon = document.getElementById('menu-close-icon');

    let isScrolled = false;

    window.addEventListener('scroll', function() {
      const scrolled = window.scrollY > 20;
      if (scrolled !== isScrolled) {
        isScrolled = scrolled;
        if (scrolled) {
          header.classList.add('glass');
          header.style.borderBottom = '1px solid var(--border)';
        } else {
          header.classList.remove('glass');
          header.style.borderBottom = 'none';
        }
      }
    }, { passive: true });

    btn.addEventListener('click', function() {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  })();
</script>
